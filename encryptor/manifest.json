{
  "manifest_version": 3,
  "name": "Simple AES Encryptor",
  "version": "1.0",
  "description": "Encrypt text using AES-256 and save to file",
  "permissions": [
    "downloads"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
